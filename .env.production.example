# Template para producción (Neon). NO contiene secretos reales.
# Uso: cp .env.production.example .env.production  y completar las creds.
# El .env.production real está gitignoreado (nunca se commitea ni entra a la imagen).

NODE_ENV=production
PORT=3000

# Postgres (Neon). El host/usuario/password los provee challenge.md.
DB_HOST=<tu-endpoint>.neon.tech
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=<neon_user>
DB_PASSWORD=<neon_password>
# Neon EXIGE SSL: sin esto, la conexión falla.
DB_SSL=true
